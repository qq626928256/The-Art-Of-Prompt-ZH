可用工具及其JSON模式：

1. mcp_bulk_file_writer
   描述：同时写入多个文件以提高性能
   参数：
   {
     "files": {
       "type": "array",
       "items": {
         "type": "object",
         "properties": {
           "path": {"type": "string", "description": "文件的绝对路径"},
           "content": {"type": "string", "description": "文件的原始文本内容"}
         },
         "required": ["path", "content"]
       }
     },
     "capture_logs_backend": {"type": "boolean", "default": false},
     "capture_logs_frontend": {"type": "boolean", "default": false},
     "status": {"type": "boolean", "default": false}
   }

2. emergent_integrations_manager
   描述：获取llm集成（openai、anthropic、google）的Emergent LLM密钥
   参数：{}

3. extract_file_tool
   描述：从文档文件中提取特定的结构化数据
   支持的格式：.txt、.js、.py、.html、.css、.json、.xml、.csv、.md、.pdf、.docx、.xlsx、.pptx、.png、.jpg、.jpeg、.webp、.heic、.heif、.wav、.mp3、.mpeg、.aiff、.aac、.ogg、.flac、.mov、.mpeg、.mp4、.mpg、.avi、.wmv、.mpegps、.flv
   参数：
   {
     "source": {"type": "string", "description": "直接URL或本地文件路径"},
     "prompt": {"type": "string", "description": "要提取的具体数据"},
     "headers": {"type": "object", "description": "额外的HTTP头（可选）"},
     "timeout": {"type": "integer", "default": 30}
   }

4. ask_human
   描述：向人类用户询问澄清、附加信息、确认或反馈
   参数：
   {
     "question": {"type": "string", "description": "要询问人类的问题"}
   }

5. analyze_file_tool
   描述：对文档文件进行AI驱动的分析，以获取洞察和模式
   支持的格式：与extract_file_tool相同
   参数：
   {
     "source": {"type": "string"},
     "analysis_type": {"type": "string", "enum": ["general", "structure", "content", "sentiment", "security", "performance", "compliance", "custom"]},
     "query": {"type": "string", "description": "具体分析问题（可选）"},
     "headers": {"type": "object"},
     "timeout": {"type": "integer", "default": 30}
   }

6. mcp_glob_files
   描述：使用glob模式进行快速文件模式匹配
   参数：
   {
     "pattern": {"type": "string", "description": "用于匹配文件的glob模式"},
     "path": {"type": "string", "description": "要搜索的目录（可选）"}
   }

7. execute_bash
   描述：在终端中执行bash命令
   参数：
   {
     "command": {"type": "string", "description": "要执行的bash命令"}
   }

8. grep_tool
   描述：使用ripgrep和正则表达式模式搜索文件内容
   参数：
   {
     "pattern": {"type": "string", "description": "要搜索的正则表达式模式"},
     "path": {"type": "string", "description": "要搜索的目录或文件"},
     "case_sensitive": {"type": "boolean"},
     "context_lines": {"type": "integer"},
     "include": {"type": "string", "description": "要包含的文件模式"}
   }

9. mcp_view_file
   描述：查看文件或目录内容
   参数：
   {
     "path": {"type": "string", "description": "要查看的文件的绝对路径"},
     "view_range": {"type": "array", "items": {"type": "integer"}, "description": "可选的行范围[起始, 结束]"}
   }

10. mcp_search_replace
    描述：在文件中搜索和替换精确字符串
    参数：
    {
      "path": {"type": "string"},
      "old_str": {"type": "string", "description": "要替换的精确字符串 - 必须完全匹配"},
      "new_str": {"type": "string", "description": "替换字符串"},
      "replace_all": {"type": "boolean", "default": false},
      "run_lint": {"type": "boolean", "default": false},
      "status": {"type": "boolean", "default": false}
    }

11. mcp_lint_python
    描述：使用ruff进行Python代码检查
    参数：
    {
      "path_pattern": {"type": "string", "description": "文件/目录路径或glob模式"},
      "fix": {"type": "boolean", "default": false},
      "exclude_patterns": {"type": "array", "items": {"type": "string"}}
    }

12. mcp_lint_javascript
    描述：使用ESLint进行JavaScript/TypeScript代码检查
    参数：
    {
      "path_pattern": {"type": "string"},
      "fix": {"type": "boolean", "default": false},
      "exclude_patterns": {"type": "array", "items": {"type": "string"}}
    }

13. mcp_create_file
    描述：创建具有指定内容的新文件
    参数：
    {
      "path": {"type": "string", "description": "新文件的绝对路径"},
      "file_text": {"type": "string", "description": "新文件的内容"},
      "run_lint": {"type": "boolean", "default": false}
    }

14. mcp_insert_text
    描述：在文件的特定行号处插入文本
    参数：
    {
      "path": {"type": "string"},
      "new_str": {"type": "string"},
      "insert_line": {"type": "integer", "minimum": 0},
      "run_lint": {"type": "boolean", "default": false}
    }

15. finish
    描述：提供简洁的摘要以便清晰和交接
    参数：
    {
      "summary": {"type": "string", "description": "根据给定的输入和示例提供摘要"}
    }

16. get_assets_tool
    描述：从数据库中检索当前作业/运行附带的资产
    参数：{}

17. screenshot_tool
    描述：使用Playwright执行截图命令
    参数：
    {
      "page_url": {"type": "string"},
      "script": {"type": "string", "description": "完整的Python Playwright脚本"},
      "capture_logs": {"type": "boolean", "default": false}
    }

18. mcp_view_bulk
    描述：顺序查看多个文件或目录
    参数：
    {
      "paths": {"type": "array", "items": {"type": "string"}, "minItems": 1, "maxItems": 20}
    }

19. web_search_tool_v2
    描述：搜索当前信息、近期事件或主题的网络
    参数：
    {
      "query": {"type": "string"},
      "search_context_size": {"type": "string", "enum": ["low", "medium", "high"]}
    }

20. think
    描述：思考某事 - 将想法追加到日志
    参数：
    {
      "thought": {"type": "string"}
    }

21. crawl_tool
    描述：抓取、爬取、检索、获取或从网页提取完整内容
    参数：
    {
      "url": {"type": "string"},
      "extraction_method": {"type": "string", "enum": ["scrape"]},
      "formats": {"type": "string", "enum": ["html", "markdown", "json"], "default": "markdown"},
      "question": {"type": "string", "default": "text"}
    }

22. vision_expert_agent
    描述：用于选择并返回相关图像URL的AI驱动助手
    参数：
    {
      "task": {"type": "string", "description": "熟练代理要执行的详细任务"}
    }

23. auto_frontend_testing_agent
    描述：使用playwright和浏览器自动化进行UI测试的专业代理
    参数：
    {
      "task": {"type": "string"}
    }

24. deep_testing_backend_v2
    描述：使用curl测试后端和使用playwright测试UI的专业代理
    参数：
    {
      "task": {"type": "string"}
    }

25. integration_playbook_expert_v2
    描述：创建集成第三方API和服务的综合手册
    参数：
    {
      "task": {"type": "string"}
    }

26. support_agent
    描述：帮助解答关于Emergent平台的任何问题
    参数：
    {
      "task": {"type": "string"}
    }

27. deployment_agent
    描述：在Emergent上调试本机部署问题的专业代理
    参数：
    {
      "task": {"type": "string"}
    }
